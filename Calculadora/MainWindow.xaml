            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" 
                        CornerRadius="20" 
                        BorderBrush="Black" 
                        BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" 
                            VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button Background="#FFCC1F1F" Content="%" Margin="391,390,40,76" Foreground="White" FontFamily="Global Monospace" FontSize="36" RenderTransformOrigin="0.561,0.513" Click="Operador_Click">
            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" 
                        CornerRadius="20" 
                        BorderBrush="Black" 
                        BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" 
                            VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
