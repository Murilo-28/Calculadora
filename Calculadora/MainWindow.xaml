    </Window.Background>
    <Grid HorizontalAlignment="Center" Width="489">
        <StackPanel Background="#FFE2E2E2" Margin="22,62,23,319"/>
        <TextBox x:Name="txtDisplay" Background="#121212" TextWrapping="Wrap" Text="" Foreground="White" FontSize="26" Margin="64,103,64,378" FontFamily="Global Monospace" TextChanged="TextBox_TextChanged"/>
        <TextBlock HorizontalAlignment="Left" Margin="209,-20,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Foreground="#FFCC1F1F" FontSize="100" Height="122"><Run Language="pt-br" Text="."/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="259,-20,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Foreground="#FFCC1F1F" FontSize="100" Height="122"><Run Language="pt-br" Text="."/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="384,104,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="85" Foreground="#FF4C4C4C"><Run Language="pt-br" Text="="/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="62,16,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Foreground="#FFCC1F1F" FontSize="150" Height="173"><Run Language="pt-br" Text="."/></TextBlock>
        <Button Content="7" HorizontalAlignment="Left" Margin="114,229,0,0" VerticalAlignment="Top" Height="65" Width="66" Click="Numero_Click" FontSize="36" FontFamily="Global Monospace" FontWeight="Bold" Foreground="White" Background="#FF4FA3A3" BorderBrush="Black"/>
