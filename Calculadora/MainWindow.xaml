        <Button Content="1" HorizontalAlignment="Left" Margin="114,357,0,0" VerticalAlignment="Top" Height="65" Width="66" FontSize="36" FontFamily="Global Monospace" FontWeight="Bold" Foreground="White" Background="#FF4FA3A3" BorderBrush="Black" Click="Numero_Click"/>
        <Button Content="2" HorizontalAlignment="Left" Margin="180,357,0,0" VerticalAlignment="Top" Height="65" Width="66" FontSize="36" FontFamily="Global Monospace" FontWeight="Bold" Foreground="White" Background="#FF4FA3A3" BorderBrush="Black" Click="Numero_Click"/>
