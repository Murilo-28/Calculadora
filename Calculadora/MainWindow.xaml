        <Button Content="x" HorizontalAlignment="Left" Margin="311,229,0,0" VerticalAlignment="Top" Height="65" Width="66" FontSize="36" FontFamily="Global Monospace" FontWeight="Bold" Click="Operador_Click" Foreground="White" Background="#FF4FA3A3" BorderBrush="Black"/>
